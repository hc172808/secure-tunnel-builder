# ──────────────────────────────────────────────────────────────
# WireGuard Manager — Docker Environment Variables
# Copy this file to .env.docker and fill in your values
# ──────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────
DB_NAME=wireguard_manager
DB_USER=wgadmin
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# PostgreSQL version (default: 14)
DB_VERSION=14

# ── Admin Account (created on first run) ─────────────────────
ADMIN_EMAIL=admin@wireguard.local
ADMIN_PASSWORD=changeme123

# ── WireGuard ────────────────────────────────────────────────
WG_SERVER_IP=10.0.0.1
WG_NETWORK=10.0.0.0/24
WG_PORT=51820
# Set to your server's public IP or domain. "auto" detects it.
WG_ENDPOINT=auto
WG_DNS=1.1.1.1
# Interface name (default: wg0)
WG_INTERFACE=wg0

# ── Supabase / Lovable Cloud (fill from your project) ───────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ── SSL / Domain (optional) ─────────────────────────────────
# Set DOMAIN and ENABLE_SSL=true for automatic Let's Encrypt
DOMAIN=
ENABLE_SSL=false
LETSENCRYPT_EMAIL=

# ── DDNS (optional) ─────────────────────────────────────────
# Supported providers: noip, duckdns, dynu, freedns, cloudflare, custom
DDNS_PROVIDER=
DDNS_HOSTNAME=
DDNS_USERNAME=
DDNS_PASSWORD=
DDNS_TOKEN=
# Cloudflare-specific
DDNS_ZONE_ID=
DDNS_RECORD_ID=
# Update interval in minutes
DDNS_INTERVAL=30

# ── Email Notifications (optional) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICATION_EMAIL=

# ── API Settings ─────────────────────────────────────────────
# Token for authenticating API requests (auto-generated if empty)
SERVER_TOKEN=
# API port (internal, proxied by Nginx)
API_PORT=3001

# ── Backup Settings ─────────────────────────────────────────
# Automatic backup interval in hours (0 = disabled)
BACKUP_INTERVAL=24
# Max number of backups to keep
BACKUP_RETENTION=7
